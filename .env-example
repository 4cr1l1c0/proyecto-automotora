# Copiar este archivo a ".env" y completar con valores reales.
# NUNCA commitear el archivo ".env" con valores reales al repositorio.

# Contraseña root de MySQL (tambien usada por cada microservicio para conectarse, DB_USERNAME=root)
MYSQL_ROOT_PASSWORD=123456

# Secreto usado por ms-auth para firmar los JWT (minimo 64 caracteres recomendado)
JWT_SECRET=DSY1103-Automotora-SecretKeyForJWT-HS256-2026-Auth
